{
  "name": "clb-vo-co-truyen-hutech-backend",
  "version": "1.0.0",
  "description": "Backend API for CLB Võ Cổ Truyền HUTECH",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/services.test.js",
    "test:integration": "jest tests/auth.test.js tests/database.test.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "init-db": "node scripts/init-db.js",
    "init-mssql": "node scripts/init-mssql.js",
    "check-mysql": "node scripts/check-mysql.js",
    "check-user": "node scripts/check-user-mssql.js",
    "get-users": "node scripts/get-all-users.js",
    "sync-users": "node scripts/sync-users-to-admin.js",
    "reset-admin": "node scripts/reset-admin-password.js",
    "update-admin": "node scripts/update-admin-profile.js",
    "auto-assign": "node scripts/auto-approve-and-assign.js",
    "test-connection": "node scripts/simple-connection-test.js",
    "check-schema": "node scripts/check-notifications-schema.js",
    "test-class-system": "node scripts/test-class-system.js",
    "mssql:manager": "node scripts/mssql-manager.js",
    "mssql:migrate": "node -e \"const MSSQLSchemaManager = require('./database/mssql-schema-manager'); new MSSQLSchemaManager().runMigrations().then(() => console.log('Migrations completed')).catch(console.error)\"",
    "mssql:migrate-002": "node scripts/run-migration-002.js",
    "mssql:status": "node -e \"const MSSQLSchemaManager = require('./database/mssql-schema-manager'); new MSSQLSchemaManager().checkDatabaseStatus().then(s => console.log(JSON.stringify(s, null, 2))).catch(console.error)\"",
    "mssql:performance": "node -e \"const {MSSQLPerformanceService} = require('./services/mssqlPerformanceService'); const p = new MSSQLPerformanceService(); p.collectMetrics().then(() => console.log(JSON.stringify(p.generatePerformanceReport(), null, 2))).catch(console.error)\"",
    "mssql:optimize": "node -e \"const {MSSQLPerformanceService} = require('./services/mssqlPerformanceService'); new MSSQLPerformanceService().optimizeDatabase().then(r => console.log('Optimizations:', r)).catch(console.error)\"",
    "mssql:backup": "node -e \"const MSSQLSchemaManager = require('./database/mssql-schema-manager'); new MSSQLSchemaManager().backupSchema().then(p => console.log('Backup created:', p)).catch(console.error)\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:restart:prod": "pm2 restart ecosystem.config.js --env production",
    "pm2:logs": "pm2 logs",
    "docker:build": "docker build -t clb-vo-api .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f api"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mssql": "^12.2.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "redis": "^4.6.10",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pm2": "^5.3.0",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "martial-arts",
    "club-management",
    "hutech",
    "api",
    "nodejs"
  ],
  "author": "CLB Võ Cổ Truyền HUTECH",
  "license": "MIT"
}
