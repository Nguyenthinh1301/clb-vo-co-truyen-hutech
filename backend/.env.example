# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
# Choose database type: mysql or mssql
DB_TYPE=mssql

# MySQL Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=clb_vo_co_truyen_hutech
DB_USER=root
DB_PASSWORD=your_password

# Microsoft SQL Server Configuration
MSSQL_SERVER=localhost\\SQLEXPRESS
MSSQL_DATABASE=clb_vo_co_truyen_hutech
MSSQL_USER=sa
MSSQL_PASSWORD=your_password
MSSQL_ENCRYPT=false

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@vocotruyenhutech.edu.vn
FROM_NAME=CLB Võ Cổ Truyền HUTECH

# Redis Configuration (for sessions and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# File Upload Configuration
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# External APIs
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_SECRET_KEY=your_vnpay_secret_key
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/api/payments/vnpay/return

# SMS Configuration (optional)
SMS_API_KEY=your_sms_api_key
SMS_SECRET_KEY=your_sms_secret_key

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log